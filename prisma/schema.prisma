generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Book {
  id              String    @id @default(cuid())
  title           String
  author          String
  publicationDate DateTime?
  pages           Int
  coverUrl        String?
  category        String
  language        String
  status          String    @default("finished")
  finishedOn      DateTime?
  rating          Int?
  externalId      String?
  source          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([finishedOn])
  @@index([category])
  @@index([status])
}
